# ===== GovMatch API 环境变量 =====

# 方式一：使用完整的 DATABASE_URL（推荐，Render PostgreSQL 会自动注入）
# 格式：postgres://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgres://your_user:your_password@your_host:5432/your_db

# 方式二：使用逐项变量（优先级高于 DATABASE_URL）
# DB_PASSWORD=your_password_here
# DB_NAME=govmatch
# DB_USER=your_user
# DB_HOST=localhost
# DB_PORT=5432

# ===== 以下为可选配置 =====

# API 拉取间隔（天），默认 7
# DAYS_BACK=7

# 日志级别（INFO/WARNING/ERROR）
# LOG_LEVEL=INFO
